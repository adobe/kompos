{
  "$schema": "http://json-schema.org/schema#",
  "description": "Kompos configuration schema",
  "type": "object",
  "properties": {
    "komposconfig": {
      "type": "object",
      "required": [
        "terraform",
        "compositions"
      ],
      "properties": {
        "defaults": {
          "type": "object",
          "properties": {
            "base_dir": {
              "type": "string",
              "description": "Base directory for generated outputs"
            },
            "use_composition_subdir": {
              "type": "boolean"
            }
          }
        },
        "compositions": {
          "type": "object",
          "properties": {
            "source": {
              "type": "object",
              "properties": {
                "local_path": {
                  "type": "string"
                },
                "root_path": {
                  "type": "string"
                }
              }
            },
            "order": {
              "type": "object",
              "properties": {
                "terraform": {
                  "type": "array",
                  "uniqueItems": true,
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "helmfile": {
                  "type": "array",
                  "uniqueItems": true,
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "properties": {
              "type": "object",
              "description": "Per-composition type properties"
            },
            "system_keys": {
              "type": "object"
            },
            "config_keys": {
              "type": "object",
              "properties": {
                "excluded": {
                  "type": "object"
                },
                "filtered": {
                  "type": "object"
                }
              }
            }
          }
        },
        "terraform": {
          "type": "object",
          "description": "Configuration related to the terraform runner",
          "properties": {
            "version": {
              "type": "string",
              "description": "The terraform version that should be used. Kompos will abort on version mismatch."
            },
            "versioned_module_sources": {
              "type": "boolean",
              "description": "Enable processing of .tf.versioned files for Terraform module source version interpolation",
              "default": true
            },
            "local_path": {
              "type": "string",
              "description": "Local file path to the terraform modules repo"
            },
            "root_path": {
              "type": "string",
              "description": "Relative to `local_path`. It should point to the modules directory"
            },
            "repo": {
              "type": "object",
              "required": [
                "name",
                "url"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "The name of the repository"
                },
                "url": {
                  "type": "string",
                  "description": "The upstream terraform modules repo"
                }
              }
            }
          }
        },
        "tfe": {
          "type": "object",
          "description": "Configuration related to the TFE runner"
        },
        "helm": {
          "type": "object",
          "description": "Configuration related to the helm runner",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "enclosing_key": { "type": "string" },
                "tfe_outputs_path": { "type": "string" },
                "output_subdir": { "type": "string" },
                "base_output_dir": { "type": "string" },
                "charts_dir": { "type": "string" },
                "bridge_filename": {
                  "type": "string",
                  "description": "Filename of the bridge template within each chart dir",
                  "default": "bridge.yaml"
                },
                "symlink_generated": {
                  "type": "boolean",
                  "description": "Create symlinks in charts/{chart}/generated/ pointing to the source of truth in generated/clusters/",
                  "default": false
                },
                "readme": {
                  "type": "boolean",
                  "description": "Generate managed README.md files for helm-values output and charts/ (requires symlink_generated for per-chart READMEs)",
                  "default": false
                },
                "readme_inventory": {
                  "type": "object",
                  "description": "Optional deployment inventory table for chart READMEs. columns[] templates use {cluster}, {chart}, and hierarchy paths (e.g. env.name). Cluster config scan runs only when a column needs hierarchy fields.",
                  "properties": {
                    "configs_marker": {
                      "type": "string",
                      "description": "Filename marking the configs/ root (default: chart_registry.yaml)"
                    },
                    "composition_type": {
                      "type": "string",
                      "description": "Composition directory name to glob for per-cluster config (default: current composition type)"
                    },
                    "group_by": {
                      "type": "string",
                      "description": "Hierarchy path to split inventory into multiple tables (e.g. env.name). The matching column is omitted from each table."
                    },
                    "group_order": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Order of group sections when group_by is set (e.g. [dev, stage, prod]). Empty groups are skipped."
                    },
                    "group_header_template": {
                      "type": "string",
                      "description": "Markdown heading per group (default: '### {group}')"
                    },
                    "chart_readmes": {
                      "type": "string",
                      "enum": ["always", "deferred", "never"],
                      "description": "When to refresh charts/*/README.md: always (each generate), deferred (once per compile or standalone generate), never"
                    },
                    "cluster_index_cache": {
                      "type": "boolean",
                      "description": "Cache cluster metadata at configs/.kompos-readme-cluster-index.yaml (default true)",
                      "default": true
                    },
                    "config_filters": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Himl filters when loading per-cluster metadata for inventory columns"
                    },
                    "columns": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "header": { "type": "string" },
                          "template": { "type": "string" },
                          "empty": { "type": "string" }
                        },
                        "required": ["header", "template"]
                      }
                    },
                    "chart_links_heading": {
                      "type": "string",
                      "description": "Markdown H2 for chart-level link table (default: Source & GitOps)"
                    },
                    "chart_registry_charts_path": {
                      "type": "string",
                      "description": "Dot path to per-chart metadata in the configs marker file (default: helm.charts)"
                    },
                    "chart_links": {
                      "type": "array",
                      "description": "Rows for chart-level link table; omit to use built-in defaults (chart_repo, version.yaml, argocd_app). Set [] to disable.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": { "type": "string" },
                          "key": { "type": "string", "description": "Registry key under helm.charts.{chart}" },
                          "from_key": { "type": "string", "description": "Derive URL from another registry key (use with path_suffix)" },
                          "path_suffix": { "type": "string", "description": "File path appended to from_key (tree→blob for GitHub)" },
                          "link_text": { "type": "string", "description": "Markdown link label; {chart} is substituted" },
                          "note": { "type": "string", "description": "Suffix after the link" }
                        },
                        "required": ["label"]
                      }
                    }
                  }
                },
                "overrides_merge": {
                  "type": "boolean",
                  "description": "Enable merging overrides/{env}.yaml and overrides/{cluster}.yaml on top of rendered bridge values",
                  "default": false
                },
                "overrides_subdir": {
                  "type": "string",
                  "description": "Subdirectory name within each chart dir for override files",
                  "default": "overrides"
                }
              }
            }
          }
        },
        "helmfile": {
          "type": "object",
          "description": "Configuration related to the helmfile runner",
          "properties": {
            "local_path": {
              "type": "string",
              "description": "Local file path to the helmfile releases repo"
            },
            "root_path": {
              "type": "string",
              "description": "Relative to `local_path`. The result is the directory of the generated hierarchical configuration file"
            },
            "repo": {
              "type": "object",
              "description": "Configuration regarding versioning",
              "required": [
                "name",
                "url"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "The name of the repository"
                },
                "url": {
                  "type": "string",
                  "description": "The upstream helmfile repo"
                }
              }
            }
          }
        },
        "min_version": {
          "type": "string",
          "description": "The minimum kompos version allowed"
        }
      }
    }
  },
  "required": [
    "komposconfig"
  ]
}
